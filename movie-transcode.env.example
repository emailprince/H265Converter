# Copy this file to movie-transcode.env and adjust for your host.

MOVIE_LIBRARY=/mnt/media-stack-library/movies
TV_LIBRARY=/mnt/media-stack-library/tv
GPU_DEVICE=/dev/dri/renderD129
QUALITY_QP=24
LOG_DIR=./transcode-logs
DRY_RUN=0

# ISO handling
MIN_MAIN_SECONDS=3600
MOUNT_ROOT=/tmp/iso-transcode-mounts

